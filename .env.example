API_KEY=dev-api-key-change-in-production

# Основная БД приложения (PostgreSQL контейнер в docker-compose публикует порт 5433)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/organizations

# БД для тестов (должна быть PostgreSQL)
TEST_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/organizations

# API-ключ, который используют тесты
TEST_API_KEY=test-api-key

